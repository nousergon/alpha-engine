{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "SpotInstanceLaunch",
            "Effect": "Allow",
            "Action": [
                "ec2:RunInstances",
                "ec2:DescribeInstances",
                "ec2:TerminateInstances",
                "ec2:CreateTags",
                "ec2:DescribeInstanceStatus"
            ],
            "Resource": "*"
        },
        {
            "Sid": "PassRoleToSpot",
            "Effect": "Allow",
            "Action": "iam:PassRole",
            "Resource": "arn:aws:iam::711398986525:role/alpha-engine-executor-role"
        }
    ]
}
